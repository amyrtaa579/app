# База данных
DATABASE_URL=postgresql+asyncpg://tpgk_user:strong_password@localhost/tpgk_bot

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT - обязательно сменить!
SECRET_KEY=your-very-strong-secret-key-at-least-32-chars

# Администратор по умолчанию
DEFAULT_ADMIN_LOGIN=admin@tpgk.ru
DEFAULT_ADMIN_PASSWORD=change_this_password
DEFAULT_ADMIN_NAME=Главный администратор

# Пути
STATIC_FILES_DIR=/home/tpgk/static
LOG_FILE=/home/tpgk/logs/app.log

# Логирование
LOG_LEVEL=INFO